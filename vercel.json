{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/jpotta run build",
  "outputDirectory": "artifacts/jpotta/dist",
  "framework": null,
  "routes": [
    { "src": "/api/admin/(login|logout|me)", "dest": "/api/admin" },
    { "src": "/api/players/(.*)", "dest": "/api/players" },
    { "src": "/api/news/(.*)", "dest": "/api/news" },
    { "src": "/api/achievements/(.*)", "dest": "/api/achievements" },
    { "src": "/api/committee/(.*)", "dest": "/api/committee" },
    { "src": "/api/reviews/(.*)", "dest": "/api/reviews" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
